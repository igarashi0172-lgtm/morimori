generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  bio           String?
  instagram     String?
  tiktok        String?
  youtube       String?
  twitter       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  posts           Post[]
  likes           Like[]
  comments        Comment[]
  submittedStores Store[]   @relation("SubmittedStores")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Store {
  id              String   @id @default(cuid())
  name            String
  address         String
  area            String
  nearestStation  String?
  genre           String
  description     String?
  imageUrl        String?
  phone           String?
  hours           String?
  closedDays      String?
  submittedById   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submittedBy User?  @relation("SubmittedStores", fields: [submittedById], references: [id], onDelete: SetNull)
  posts       Post[]
  menus       Menu[]
}

model Menu {
  id          String  @id @default(cuid())
  storeId     String
  name        String
  price       Int?
  description String?
  imageUrl    String?
  isChallenge Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Post {
  id          String   @id @default(cuid())
  userId      String
  storeId     String?
  title       String
  body        String?
  mediaUrls   String   @default("[]")
  mediaType   String   @default("image")
  isCompleted Boolean  @default(false)
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  store    Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  likes    Like[]
  comments Comment[]
}

model Like {
  id     String @id @default(cuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Inquiry {
  id             String   @id @default(cuid())
  type           String
  storeName      String?
  storeId        String?
  body           String
  name           String?
  email          String?
  status         String   @default("open")
  // 新規登録・新規オープン用の店舗情報
  storeAddress   String?
  storeArea      String?
  storeStation   String?
  storeGenre     String?
  storePhone     String?
  storeHours     String?
  storeClosedDays String?
  storeImageUrl  String?
  storeDesc      String?
  submittedById  String?
  createdAt      DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  body      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}
